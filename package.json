{
  "name": "cvicc",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "tokens": "npx ts-node --project tsconfig.scripts.json scripts/generate-tokens.ts",
    "generate-members": "npx ts-node --project tsconfig.scripts.json scripts/generate-members.ts",
    "dev": "npm run tokens && ./node_modules/.bin/next dev",
    "build": "npm run tokens && npm run generate-members && ./node_modules/.bin/next build",
    "start": "./node_modules/.bin/next start",
    "lint": "./node_modules/.bin/next lint"
  },
  "dependencies": {
    "@portabletext/react": "^6.0.3",
    "@sanity/image-url": "^2.1.1",
    "@sanity/vision": "^5.19.0",
    "@vercel/analytics": "^2.0.1",
    "lucide-react": "^1.7.0",
    "next": "14.2.35",
    "next-sanity": "^12.2.1",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
